{
  "name": "autolease-api",
  "version": "1.0.0",
  "description": "Car Rental & Marketplace API - Node.js, Express, JavaScript MVC",
  "main": "src/server.js",
  "scripts": {
    "build": "node --check src/server.js",
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "node --test",
    "seed": "node src/database/seeders/index.js",
    "migrate:create": "node-pg-migrate create",
      "migrate:up": "node-pg-migrate up",
      "migrate:down": "node-pg-migrate down"
    
  },
  "keywords": [
    "car-rental",
    "marketplace",
    "mvc",
    "nodejs",
    "express"
  ],
  "license": "ISC",
  "dependencies": {
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.34.5",
    "cloudinary": "^2.5.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "google-auth-library": "^10.9.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-pg-migrate": "^8.0.4",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.20",
    "uuid": "^11.0.3",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.24",
    "@types/ws": "^8.5.13",
    "nodemon": "^3.1.14"
  },
  "directories": {
    "doc": "docs",
    "test": "test"
  },
  "author": "",
  "type": "commonjs"
}
